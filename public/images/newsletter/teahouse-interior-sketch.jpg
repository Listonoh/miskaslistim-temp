<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" width="800" height="450">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="rgb(200,185,155)"/>
      <stop offset="100%" stop-color="rgb(224,212,189)"/>
    </linearGradient>
    <linearGradient id="floor" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgb(180,160,120)"/>
      <stop offset="100%" stop-color="rgb(155,138,105)"/>
    </linearGradient>
  </defs>
  <!-- Background wall -->
  <rect width="800" height="450" fill="url(#bg)"/>
  <!-- Floor -->
  <polygon points="0,320 800,280 800,450 0,450" fill="url(#floor)"/>
  <!-- Window -->
  <rect x="320" y="60" width="160" height="200" rx="6" fill="rgb(210,225,230)" stroke="rgb(140,120,80)" stroke-width="4"/>
  <line x1="400" y1="60" x2="400" y2="260" stroke="rgb(140,120,80)" stroke-width="3"/>
  <line x1="320" y1="160" x2="480" y2="160" stroke="rgb(140,120,80)" stroke-width="3"/>
  <!-- Low table -->
  <rect x="240" y="295" width="320" height="18" rx="4" fill="rgb(130,105,70)" stroke="rgb(100,80,45)" stroke-width="2"/>
  <rect x="265" y="313" width="16" height="45" rx="3" fill="rgb(115,92,62)"/>
  <rect x="519" y="313" width="16" height="45" rx="3" fill="rgb(115,92,62)"/>
  <!-- Tea pot on table -->
  <ellipse cx="380" cy="293" rx="22" ry="14" fill="rgb(165,152,123)" stroke="rgb(110,90,55)" stroke-width="2"/>
  <ellipse cx="380" cy="285" rx="14" ry="9" fill="rgb(180,165,135)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <path d="M360 289 Q345 283 347 295 Q349 300 360 296" fill="rgb(165,152,123)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <rect x="375" y="275" width="10" height="6" rx="3" fill="rgb(180,165,135)" stroke="rgb(110,90,55)" stroke-width="1"/>
  <!-- Tea cups -->
  <ellipse cx="430" cy="296" rx="12" ry="7" fill="rgb(224,212,189)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <path d="M420 296 Q418 304 430 306 Q442 304 440 296" fill="rgb(224,212,189)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <ellipse cx="460" cy="296" rx="12" ry="7" fill="rgb(224,212,189)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <path d="M450 296 Q448 304 460 306 Q472 304 470 296" fill="rgb(224,212,189)" stroke="rgb(110,90,55)" stroke-width="1.5"/>
  <!-- Cushion on floor -->
  <ellipse cx="300" cy="330" rx="55" ry="20" fill="rgb(185,155,105)" stroke="rgb(140,115,70)" stroke-width="2"/>
  <ellipse cx="500" cy="335" rx="55" ry="20" fill="rgb(175,148,100)" stroke="rgb(140,115,70)" stroke-width="2"/>
  <!-- Plant in corner -->
  <rect x="80" y="305" width="28" height="38" rx="4" fill="rgb(150,130,95)" stroke="rgb(110,90,60)" stroke-width="2"/>
  <ellipse cx="94" cy="290" rx="30" ry="35" fill="rgb(90,120,65)" stroke="rgb(65,95,45)" stroke-width="2"/>
  <path d="M94 255 Q80 235 68 245 Q82 240 94 260" fill="rgb(100,135,72)"/>
  <path d="M94 255 Q108 235 120 248 Q106 240 94 260" fill="rgb(95,128,68)"/>
  <!-- Lantern hanging -->
  <line x1="640" y1="0" x2="640" y2="80" stroke="rgb(130,110,75)" stroke-width="2"/>
  <ellipse cx="640" cy="100" rx="22" ry="32" fill="rgb(220,180,100)" stroke="rgb(160,120,55)" stroke-width="2" opacity="0.85"/>
  <line x1="618" y1="80" x2="662" y2="80" stroke="rgb(160,120,55)" stroke-width="1.5"/>
  <line x1="618" y1="120" x2="662" y2="120" stroke="rgb(160,120,55)" stroke-width="1.5"/>
  <!-- Text label -->
  <text x="400" y="430" text-anchor="middle" font-family="Georgia, serif" font-size="16" fill="rgb(100,80,45)" opacity="0.7">
    Interiér čajovny · Teahouse interior sketch
  </text>
</svg>
