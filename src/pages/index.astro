---
---
<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Míškas Čajovna — brzy otevíráme v Praze u Nádraží Libeň" />
    <title>Míškas Čajovna | Coming Soon</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
      }

      body {
        font-family: Georgia, 'Times New Roman', serif;
        background-color: rgb(224, 212, 189);
        color: rgb(72, 58, 38);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      /* ── Tree silhouette background ── */
      .tree-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
      }

      /* ── Content card ── */
      .content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2.5rem 2rem;
        max-width: 560px;
        width: 90%;
        background: rgba(224, 212, 189, 0.62);
        backdrop-filter: blur(6px);
        border-radius: 1.5rem;
        box-shadow: 0 4px 32px rgba(90, 70, 30, 0.15);
      }

      /* ── Logo ── */
      .logo {
        width: 120px;
        height: 120px;
        margin-bottom: 1.5rem;
      }

      /* ── Teahouse name ── */
      .site-name {
        font-size: 2rem;
        font-weight: normal;
        letter-spacing: 0.08em;
        color: rgb(90, 70, 35);
        margin-bottom: 0.35rem;
      }

      .site-subtitle {
        font-size: 0.85rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgb(140, 120, 80);
        margin-bottom: 2rem;
      }

      /* ── Main message ── */
      .message {
        margin-bottom: 0.75rem;
      }

      .message-cz {
        font-size: 1.2rem;
        font-style: italic;
        color: rgb(80, 64, 38);
        margin-bottom: 0.4rem;
      }

      .message-en {
        font-size: 0.95rem;
        color: rgb(120, 100, 65);
        letter-spacing: 0.04em;
      }

      .location {
        font-size: 0.85rem;
        color: rgb(140, 120, 80);
        margin-top: 0.5rem;
        margin-bottom: 2rem;
      }

      /* ── Newsletter button ── */
      .btn-newsletter {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: rgb(165, 152, 123);
        color: rgb(248, 242, 228);
        text-decoration: none;
        border-radius: 3rem;
        font-family: Georgia, serif;
        font-size: 0.95rem;
        letter-spacing: 0.06em;
        border: 2px solid rgb(140, 128, 100);
        transition: background 0.25s, color 0.25s, transform 0.15s;
        cursor: pointer;
      }

      .btn-newsletter:hover {
        background: rgb(140, 128, 100);
        color: rgb(255, 250, 240);
        transform: translateY(-2px);
      }

      .btn-newsletter:active {
        transform: translateY(0);
      }
    </style>
  </head>
  <body>

    <!-- Tree silhouette background SVG -->
    <svg class="tree-bg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice"
         xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="treeGrad" x1="0" y1="1" x2="0" y2="0">
          <stop offset="0%" stop-color="rgb(145, 133, 105)" stop-opacity="1"/>
          <stop offset="100%" stop-color="rgb(185, 170, 140)" stop-opacity="0.55"/>
        </linearGradient>
      </defs>

      <!-- Left large tree -->
      <g fill="url(#treeGrad)" stroke="none">
        <!-- trunk -->
        <rect x="48" y="600" width="28" height="300" rx="8"/>
        <!-- branch L1 left -->
        <rect x="20" y="440" width="22" height="220" rx="7"
              transform="rotate(-22 20 440)"/>
        <!-- sub-branch L1-left-a -->
        <rect x="-18" y="310" width="16" height="150" rx="5"
              transform="rotate(-15 -18 310)"/>
        <!-- sub-branch L1-left-b -->
        <rect x="10" y="285" width="14" height="130" rx="5"
              transform="rotate(10 10 285)"/>
        <!-- branch L1 right -->
        <rect x="75" y="460" width="22" height="200" rx="7"
              transform="rotate(20 75 460)"/>
        <!-- sub-branch L1-right-a -->
        <rect x="110" y="330" width="16" height="145" rx="5"
              transform="rotate(14 110 330)"/>
        <!-- sub-branch L1-right-b -->
        <rect x="82" y="310" width="14" height="130" rx="5"
              transform="rotate(-8 82 310)"/>
        <!-- top branch -->
        <rect x="55" y="380" width="18" height="240" rx="6"
              transform="rotate(4 55 380)"/>
        <!-- top sub-branch a -->
        <rect x="42" y="220" width="13" height="160" rx="5"
              transform="rotate(-12 42 220)"/>
        <!-- top sub-branch b -->
        <rect x="68" y="215" width="12" height="145" rx="5"
              transform="rotate(10 68 215)"/>
      </g>

      <!-- Right large tree -->
      <g fill="url(#treeGrad)" stroke="none">
        <rect x="1360" y="600" width="28" height="300" rx="8"/>
        <rect x="1370" y="440" width="22" height="220" rx="7"
              transform="rotate(22 1370 440)"/>
        <rect x="1400" y="295" width="16" height="155" rx="5"
              transform="rotate(16 1400 295)"/>
        <rect x="1378" y="280" width="14" height="130" rx="5"
              transform="rotate(-9 1378 280)"/>
        <rect x="1340" y="455" width="22" height="200" rx="7"
              transform="rotate(-20 1340 455)"/>
        <rect x="1300" y="325" width="16" height="148" rx="5"
              transform="rotate(-14 1300 325)"/>
        <rect x="1325" y="305" width="14" height="130" rx="5"
              transform="rotate(7 1325 305)"/>
        <rect x="1365" y="375" width="18" height="235" rx="6"
              transform="rotate(-3 1365 375)"/>
        <rect x="1350" y="215" width="13" height="162" rx="5"
              transform="rotate(-11 1350 215)"/>
        <rect x="1373" y="210" width="12" height="148" rx="5"
              transform="rotate(10 1373 210)"/>
      </g>

      <!-- Far-left background tree (smaller, lighter) -->
      <g fill="url(#treeGrad)" opacity="0.45">
        <rect x="170" y="680" width="18" height="220" rx="6"/>
        <rect x="176" y="520" width="15" height="200" rx="5"
              transform="rotate(-18 176 520)"/>
        <rect x="152" y="390" width="12" height="140" rx="4"
              transform="rotate(-12 152 390)"/>
        <rect x="180" y="380" width="11" height="130" rx="4"
              transform="rotate(14 180 380)"/>
        <rect x="190" y="530" width="14" height="185" rx="5"
              transform="rotate(16 190 530)"/>
        <rect x="205" y="405" width="11" height="135" rx="4"
              transform="rotate(12 205 405)"/>
      </g>

      <!-- Far-right background tree -->
      <g fill="url(#treeGrad)" opacity="0.45">
        <rect x="1252" y="680" width="18" height="220" rx="6"/>
        <rect x="1255" y="520" width="15" height="200" rx="5"
              transform="rotate(18 1255 520)"/>
        <rect x="1270" y="390" width="12" height="140" rx="4"
              transform="rotate(12 1270 390)"/>
        <rect x="1244" y="380" width="11" height="130" rx="4"
              transform="rotate(-14 1244 380)"/>
        <rect x="1235" y="535" width="14" height="182" rx="5"
              transform="rotate(-16 1235 535)"/>
        <rect x="1220" y="408" width="11" height="132" rx="4"
              transform="rotate(-12 1220 408)"/>
      </g>

      <!-- Centre-left mid tree -->
      <g fill="url(#treeGrad)" opacity="0.3">
        <rect x="340" y="720" width="14" height="180" rx="5"/>
        <rect x="344" y="580" width="12" height="170" rx="4"
              transform="rotate(-16 344 580)"/>
        <rect x="325" y="450" width="10" height="120" rx="4"
              transform="rotate(-10 325 450)"/>
        <rect x="353" y="445" width="9" height="110" rx="3"
              transform="rotate(12 353 445)"/>
        <rect x="356" y="585" width="12" height="160" rx="4"
              transform="rotate(18 356 585)"/>
      </g>

      <!-- Centre-right mid tree -->
      <g fill="url(#treeGrad)" opacity="0.3">
        <rect x="1086" y="720" width="14" height="180" rx="5"/>
        <rect x="1090" y="580" width="12" height="170" rx="4"
              transform="rotate(16 1090 580)"/>
        <rect x="1103" y="450" width="10" height="120" rx="4"
              transform="rotate(10 1103 450)"/>
        <rect x="1074" y="445" width="9" height="110" rx="3"
              transform="rotate(-12 1074 445)"/>
        <rect x="1072" y="585" width="12" height="160" rx="4"
              transform="rotate(-18 1072 585)"/>
      </g>
    </svg>

    <!-- Main content -->
    <main class="content">

      <!-- Logo: bowl with leaves -->
      <svg class="logo" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg"
           aria-label="Čajovna logo – miska s lístky">
        <!-- Bowl body -->
        <path d="M18 52 Q18 95 60 95 Q102 95 102 52 Z"
              fill="rgb(165, 152, 123)" stroke="rgb(110, 95, 65)" stroke-width="3.5"/>
        <!-- Bowl rim -->
        <rect x="14" y="46" width="92" height="12" rx="6"
              fill="rgb(145, 133, 105)" stroke="rgb(100, 85, 55)" stroke-width="3"/>
        <!-- Steam lines -->
        <path d="M46 38 Q42 28 46 18 Q50 8 46 0"
              fill="none" stroke="rgb(130, 115, 85)" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M60 36 Q56 24 60 14 Q64 4 60 -4"
              fill="none" stroke="rgb(130, 115, 85)" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M74 38 Q70 28 74 18 Q78 8 74 0"
              fill="none" stroke="rgb(130, 115, 85)" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Leaf 1 (left) -->
        <ellipse cx="44" cy="68" rx="14" ry="7"
                 fill="rgb(110, 130, 80)" stroke="rgb(80, 100, 50)" stroke-width="1.5"
                 transform="rotate(-30 44 68)"/>
        <line x1="38" y1="72" x2="50" y2="64"
              stroke="rgb(80, 100, 50)" stroke-width="1" stroke-linecap="round"/>
        <!-- Leaf 2 (centre) -->
        <ellipse cx="60" cy="72" rx="15" ry="7"
                 fill="rgb(120, 145, 85)" stroke="rgb(80, 100, 50)" stroke-width="1.5"/>
        <line x1="53" y1="72" x2="67" y2="72"
              stroke="rgb(80, 100, 50)" stroke-width="1" stroke-linecap="round"/>
        <!-- Leaf 3 (right) -->
        <ellipse cx="76" cy="68" rx="14" ry="7"
                 fill="rgb(100, 125, 75)" stroke="rgb(80, 100, 50)" stroke-width="1.5"
                 transform="rotate(30 76 68)"/>
        <line x1="70" y1="64" x2="82" y2="72"
              stroke="rgb(80, 100, 50)" stroke-width="1" stroke-linecap="round"/>
        <!-- Bowl base/foot -->
        <rect x="48" y="93" width="24" height="6" rx="3"
              fill="rgb(145, 133, 105)" stroke="rgb(100, 85, 55)" stroke-width="2"/>
        <rect x="40" y="98" width="40" height="5" rx="2.5"
              fill="rgb(145, 133, 105)" stroke="rgb(100, 85, 55)" stroke-width="2"/>
      </svg>

      <h1 class="site-name">Míškas Čajovna</h1>
      <p class="site-subtitle">Praha · Nádraží Libeň</p>

      <div class="message">
        <p class="message-cz">Připravujeme pro vás čajovnu.</p>
        <p class="message-en">We are in the process of preparing the teahouse.</p>
      </div>
      <p class="location">📍 Praha, u Nádraží Libeň</p>

      <a class="btn-newsletter" href="/newsletter">
        Přihlaste se k odběru novinek &nbsp;/&nbsp; Subscribe to Newsletter
      </a>
    </main>

  </body>
</html>
